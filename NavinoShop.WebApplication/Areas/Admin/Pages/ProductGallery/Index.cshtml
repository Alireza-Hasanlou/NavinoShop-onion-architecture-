@page
@model NavinoShop.WebApplication.Areas.Admin.Pages.ProductGallery.IndexModel
@using Shared.Application
@using Shared.Domain.Enums
@{
    Layout = "_AdminLayout";
    ViewData["title"] = "ویژگی های محصول";
    var successMessage = TempData["success"] as string;

}
<div class="box">
    <div class="box-body">
        <div id="example1_wrapper" class="dataTables_wrapper form-inline dt-bootstrap">
            <div class="box-header">
                <h3 class="box-title">@Model.Gallery.Title</h3>
                <input type="hidden" id="ProductId" value="@Model.Gallery.ProductId" />
            </div>

            <div class="row">
                <div class="col col-lg-2 col-sm-12">
                    <a onclick="open_Modal_Ajax('/Admin/ProductGallery/Create','')" class="btn btn-success"><i class="fa fa-plus"></i></a>
                </div>
                <div class="col-md-12">
                    <table class="DataTable table table-bordered table-striped dataTable" role="grid" aria-describedby="example1_info">
                        <thead>
                            <tr role="row">
                                <th>تصویر</th>
                                <th> Alt تصویر</th>
                                <th>عملیات</th>
                                
                        </thead>
                        <tbody>
                            @if (Model.Gallery.ProductGalleries.Count > 0)
                            {
                                @foreach (var item in Model.Gallery.ProductGalleries)
                                {
                                    <tr id="@item.Id role="row" class="odd">
                                        <td ><img src="@FileDirectories.ProductGalleryImageDirectory100@item.ImageName" style="width:100px;"/></td>
                                        <td>@item.ImageAlt</td>
                                        <td>

                                            <div class="btn-group">
                                                <a onclick="DeleteAjax('   آیا از حذف این تصویر مطئن هستید؟ ','این عملیات غیر قابل بازگشت خواهد بود', 'warning', 'بله', '/Admin/ProductGallery/Delete',@item.Id)" class="btn btn-danger" title="حذف"><i class="fa fa-trash"></i></a>
                                            </div>


                                        </td>

                                    </tr>

                                }
                            }

                        </tbody>

                    </table>

                </div>
            </div>

        </div>
    </div>
</div>



