@using Shared.Application
@using Shop.Application.Contract.Product.Command
@model EditProductCommandModel
<div class="product-form-wrapper">

    <div class="product-form-body">
        <form id="productForm" method="post" enctype="multipart/form-data">
            <div class="product-form-row">
                <input type="hidden" id="ProductId" asp-for="Id" />
                <input type="hidden" id="ImageName" asp-for="ImageName" />
                <!-- ستون راست -->
                <div class="product-form-col">
                    <!-- عنوان -->
                    <div class="product-form-group">
                        <label class="product-form-label">
                            عنوان <span class="required-star">*</span>
                        </label>
                        <input type="text" asp-for="Title" class="product-form-control" id="Title" name="Title"
                               placeholder="عنوان محصول" maxlength="250">
                        <div class="product-form-info"><span id="titleCount">0</span>/250 کاراکتر</div>
                        <div class="product-form-validation" data-for="Title">لطفا عنوان را وارد کنید</div>
                    </div>

                    <!-- Alt تصویر -->
                    <div class="product-form-group">
                        <label class="product-form-label">
                            Alt تصویر <span class="required-star">*</span>
                        </label>
                        <input type="text" asp-for="ImageAlt" class="product-form-control" id="ImageAlt" name="ImageAlt"
                               placeholder="توضیح تصویر برای سئو" maxlength="150">
                        <div class="product-form-info"><span id="AltCount">0</span>/600 کاراکتر</div>
                        <div class="product-form-validation" data-for="ImageAlt">لطفا Alt تصویر را وارد کنید</div>
                    </div>

                    <!-- توضیح مختصر -->
                    <div class="product-form-group">
                        <label class="product-form-label">
                            توضیح مختصر <span class="required-star">*</span>
                        </label>
                        <textarea asp-for="ShortDescription" class="product-form-textarea" id="ShortDescription" name="ShortDescription"
                                  rows="3" placeholder="توضیح مختصر محصول..." maxlength="600"></textarea>
                        <div class="product-form-info"><span id="shortDescCount">0</span>/600 کاراکتر</div>
                        <div class="product-form-validation" data-for="ShortDescription">لطفا توضیح مختصر را وارد کنید</div>
                    </div>

                    <!-- دسته بندی ها با قابلیت اسکرول -->
                    <div class="scroll-checkbox-wrapper">
                        <div class="scroll-checkbox-container">
                            <div class="scroll-checkbox-box">
                                <div class="scroll-checkbox-header">
                                    <span>دسته بندی های محصول</span>
                                    <span class="scroll-checkbox-count" id="selectedCount">0</span>
                                </div>

                                @foreach (var item in Model.Categories)
                                {
                                    <div class="scroll-checkbox-item">
                                        <div class="custom-checkbox-container">
                                            <input class="custom-checkbox-input category-checkbox"
                                                   id="cat-@item.Id"
                                                   name="CategoryIds"
                                                   type="checkbox"
                                                   value="@item.Id"
                                                   @(Model.SelectedCategory != null && Model.SelectedCategory.Contains(item.Id) ? "checked" : "")>
                                            <label class="custom-checkbox-label" for="cat-@item.Id">
                                                <span class="custom-checkbox-text">@item.Title</span>
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ستون چپ -->
                <div class="product-form-col">
                    <!-- لینک سربرگ -->
                    <div class="product-form-group">
                        <label class="product-form-label">
                            لینک سربرگ (Slug) <span class="required-star">*</span>
                        </label>
                        <input asp-for="Slug" type="text" class="product-form-control" id="Slug" name="Slug"
                               placeholder="slug-product" maxlength="300">
                        <div class="product-form-info"><span id="slugCount">0</span>/300 کاراکتر</div>
                        <div class="product-form-validation" data-for="Slug">لطفا Slug را وارد کنید</div>
                    </div>

                    <!-- وزن -->
                    <div class="product-form-group">
                        <label class="product-form-label">
                            وزن (گرم) <span class="required-star">*</span>
                        </label>
                        <input type="number" asp-for="Weight" class="product-form-control" id="Weight" name="Weight"
                               placeholder="وزن به گرم" min="0" step="1">
                        <div class="product-form-validation" data-for="Weight">لطفا وزن را وارد کنید</div>
                    </div>

                    <!-- توضیحات کامل -->
                    <div class="product-form-group">
                        <label class="product-form-label">
                            توضیحات کامل <span class="required-star">*</span>
                        </label>
                        <textarea asp-for="Text" class="product-form-textarea" id="Text" name="Text"
                                  rows="5" placeholder="توضیحات کامل محصول..."></textarea>
                        <div class="product-form-validation" data-for="Text">لطفا توضیحات را وارد کنید</div>
                    </div>

                    <!-- آپلود تصویر -->
                    <div class="col  col-sm-12 col-12">
                        <div id="img-container">
                            <label for="upload-file">
                                تصویر محصول
                                <div class="picture-uploader" data-url="@FileDirectories.ProductImageDirectory500@Model.ImageName">
                                    <div class="picture__image">Choose an image</div>

                                    <input type="file" id="upload-file" class="picture__input" accept="image/*" />
                                </div>
                            </label>
                        </div>

                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal-footer p-4">
    <button type="button" class="btn btn-default pull-left" onclick="close_Modal_Ajax()">خروج</button>
    <button type="button" class="btn btn-primary" onclick="EditProduct()">ذخیره</button>
</div>

<script>
    $(document).ready(function() {
        $(".picture-uploader").imageUploader();

        CharCounter('#ShortDescription', '#shortDescCount', 600);
        CharCounter('#Title', '#titleCount', 250);
        CharCounter('#ImageAlt', '#AltCount', 250);
         CharCounter('#Slug', '#slugCount', 600);

        AutoSlug('#Title', '#Slug', { maxLength: 300 });

        CheckboxCounter('.category-checkbox', '#selectedCount');
    });
</script>

