@using Discount.Application.Contract.ProductDiscount.Command
@model UpsertProductDiscountCommandModel

<div class="modal-body">
    <form id="addDiscountForm" asp-action="AddDiscount" asp-controller="Discount" method="post">
        <h4>افزودن تخفیف</h4>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <input type="hidden" id="ProductId" name="ProductId" value="@Model.ProductId" />
        <input type="hidden" id="ProductSellId" name="ProductSellId" value="@Model.ProductSellId" />

        <div class="form-group mb-3">
            <label asp-for="DiscountPercent" class="control-label">درصد تخفیف</label>
            <input asp-for="DiscountPercent" id="DiscountPercent" class="form-control" />
            <span asp-validation-for="DiscountPercent" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label class="control-label">تاریخ شروع</label>
            <input asp-for="StartDate" type="text" id="StartDate" name="StartDate" class="form-control" autocomplete="off" />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label class="control-label">تاریخ پایان</label>
            <input asp-for="EndDate" type="text" id="EndDate" name="EndDate" class="form-control" autocomplete="off" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>

        <div class="modal-footer p-4">
            <button type="button" class="btn btn-default pull-left" onclick="close_Modal_Ajax()">خروج</button>
            <button type="button" onclick="addDiscount(this)" class="btn btn-primary">ثبت تخفیف</button>
        </div>
    </form>
</div>
<script>

    $("#StartDate").persianDatepicker({
        formatDate: "YYYY/MM/DD",
        persianNumbers: false
    });

    $("#EndDate").persianDatepicker({
        formatDate: "YYYY/MM/DD",
        persianNumbers: false
    });


</script>