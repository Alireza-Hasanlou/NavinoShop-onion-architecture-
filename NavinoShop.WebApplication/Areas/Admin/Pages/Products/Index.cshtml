@page "{pageId:int?}/{take:int?}/{filter?}"
@model NavinoShop.WebApplication.Areas.Admin.Pages.Products.IndexModel
@using Shared.Application
@using Shared.Domain.Enums
@{
    Layout = "_AdminLayout";
    ViewData["title"] = "محصولات ";
    var successMessage = TempData["success"] as string;

}
<div class="box">
    <div class="box-body">
        <div id="example1_wrapper" class="dataTables_wrapper form-inline dt-bootstrap">
            <div class="box-header">
                <h3 class="box-title">@Model.Products.Title</h3>
            </div>

            <div class="row col-12">
                <form>
                    <input type="hidden" asp-for="Products.PageId" />

                    <div class="row col col-lg-12">
                        <div class="col col-lg-2 col-sm-12">
                            <label>
                                جستجو:
                                <input name="filter" type="search" class="form-control input-sm" placeholder="" aria-controls="DataTables_Table_0">
                            </label>
                        </div>
                        <div class="col col-lg-2 col-sm-12">
                            <label>
                                نمایش
                                <select asp-for="Products.Take" name="take" aria-controls="DataTables_Table_0" class="form-control input-sm">
                                    <option value="10">10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                    <option value="100">100</option>
                                </select>

                            </label>
                        </div>
                        <div class="col col-lg-2 col-sm-12">
                            <button class="btn btn-info" title="جست و جو"><i class="fa fa-search"></i></button>
                        </div>
                        <div class="col col-lg-2 col-sm-12">
                            <a onclick="open_Modal_Ajax('/Admin/Products/Create','product-modal')" class="btn btn-success">افزودن محصول جدید</a>
                        </div>
                    </div>
                    <br />
                </form>
            </div>
            <div class="row">
                <div class="col-sm-12">
                    <table class="ImageDataTable table table-bordered table-striped dataTable" role="grid">
                        <thead>
                            <tr role="row">
                                <th>تصویر</th>
                                <th>عنوان</th>
                                <th>سربرگ</th>
                                <th>توضیح کوتاه</th>
                                <th> وزن</th>
                                <th>وضعیت</th>
                                <th>تخفیف</th>
                                <th>تاریخ ایجاد</th>
                                <th>تاریخ ویرایش</th>
                                <th>گالری</th>
                                <th style="width:120px">عملیات</th>

                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Products.products)
                            {
                                <tr id="@item.Id">
                                    <td>
                                        <img style="width:100px" src="@FileDirectories.ProductImageDirectory100@item.ImageName" />
                                    </td>
                                    <td>@item.Title</td>
                                    <td>@item.Slug</td>
                                    <td>@item.ShortDescription</td>
                                    <td>@item.Weight</td>
                                    <td>
                                        @{
                                            string title = item.Active ? "غیر فعال شود ؟؟؟" : "فعال شود ؟؟؟";
                                            string text = item.Active ? "بعد از غیر فعال شدن این  محصول  نمایش داده نمیشود ." : "بعد از فعال شدن این محصول نمایش داده میشود";
                                            string cancel = item.Active ? "فعال بماند" : "غیر فعال بماند";
                                            string confirm = item.Active ? "غیر فعال شود" : "فعال شود";
                                        }
                                        <!-- From Uiverse.io by Galahhad -->
                                        <div onclick="AjaxSweetNotDelete(
                                                                                                                     '@title',
                                                                                                                     '@text',
                                                                                                                     'question',
                                                                                                                     '@confirm',
                                                                                                                      '@cancel',
                                                                                                                      '/Admin/Products/ChangeActivation',
                                                                                                                      '@item.Id' )" class="switch">
                                            <input id="@item.Id" @(item.Active ? "checked" : "") type="checkbox">
                                            <div class="slider">
                                                <div class="circle">
                                                    <svg class="cross" xml:space="preserve" style="enable-background:new 0 0 512 512" viewBox="0 0 365.696 365.696" y="0" x="0" height="6" width="6" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" xmlns="http://www.w3.org/2000/svg">
                                                    <g>
                                                    <path data-original="#000000" fill="currentColor" d="M243.188 182.86 356.32 69.726c12.5-12.5 12.5-32.766 0-45.247L341.238 9.398c-12.504-12.503-32.77-12.503-45.25 0L182.86 122.528 69.727 9.374c-12.5-12.5-32.766-12.5-45.247 0L9.375 24.457c-12.5 12.504-12.5 32.77 0 45.25l113.152 113.152L9.398 295.99c-12.503 12.503-12.503 32.769 0 45.25L24.48 356.32c12.5 12.5 32.766 12.5 45.247 0l113.132-113.132L295.99 356.32c12.503 12.5 32.769 12.5 45.25 0l15.081-15.082c12.5-12.504 12.5-32.77 0-45.25zm0 0"></path>
                                                                    </g>
                                                                </svg>
                                                    <svg class="checkmark" xml:space="preserve" style="enable-background:new 0 0 512 512" viewBox="0 0 24 24" y="0" x="0" height="10" width="10" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" xmlns="http://www.w3.org/2000/svg">
                                                    <g>
                                                    <path class="" data-original="#000000" fill="currentColor" d="M9.707 19.121a.997.997 0 0 1-1.414 0l-5.646-5.647a1.5 1.5 0 0 1 0-2.121l.707-.707a1.5 1.5 0 0 1 2.121 0L9 14.171l9.525-9.525a1.5 1.5 0 0 1 2.121 0l.707.707a1.5 1.5 0 0 1 0 2.121z"></path>
                                                                    </g>
                                                                </svg>
                                                </div>
                                            </div>
                                        </div>

                                    </td>
                                    <td>@item.DiscountPercent %</td>
                                    <td>@item.CreateDate.ToPersainDate()</td>
                                    <td>@item.UpdateDate.ToPersainDate()</td>
                                    <td> <a href="/Admin/ProductGallery/Index?ProductId=@item.Id" class="btn btn-secondary" title="گالری تصاویر"><i class="fa fa-image"></i></a></td>
                                    <td >
                                        <div class="btn-group">
                                            <a onclick="open_Modal_Ajax('/Admin/Products/Edit?Id=@item.Id','product-modal')" title="ویرایش" class="btn btn-warning"><i class="fa fa-edit"></i></a>
                                            <a href="/Admin/ProductFeatures/Index?ProductId=@item.Id" class="btn btn-info" title="ویژگی ها محصول"><i class="fa fa-info"></i></a>
                                            <a href="/Admin/Seo/Index?Id=@item.Id&where=@WhereSeo.Product" title="سئو" class="btn btn-danger" target="_blank">S</a>
                                            <a onclick="open_Modal_Ajax('/Admin/Products/AddDiscount/@item.Id','')" title="تخفیف" class="btn custom-btn-discount"><i class="fa fa-tag"></i></a>
                                        </div>
                                    </td>

                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>

            @if (Model.Products.PageCount > 1)
            {
                <div class="row">
                    <div class="col-sm-5"></div>
                    <div class="col-sm-7">
                        <div class="dataTables_paginate paging_simple_numbers" id="DataTables_Table_0_paginate">
                            <ul class="pagination">
                                @if (Model.Products.PageId > 1)
                                {

                                    <li class="paginate_button ">
                                        <a href="/Admin/Products/Index?pageId=@(Model.Products.PageId - 1)&take=@Model.Products.Take&filter=@Model.Products.Filter&CategoryId=@(Model.Products.CategoryId)"
                                           aria-controls="DataTables_Table_0" data-dt-idx="1" tabindex="0">«</a>
                                    </li>
                                }

                                @for (int i = Model.Products.StartPage; i <= Model.Products.EndPage; i++)
                                {
                                    <li class="paginate_button  @((Model.Products.PageId == i) ? "active" : "")">
                                        <a href="/Admin/Products/Index?pageId=@(i)&take=@Model.Products.Take&filter=@Model.Products.Filter&CategoryId=@(Model.Products.CategoryId)"
                                           aria-controls="DataTables_Table_0" data-dt-idx="1" tabindex="0">@i</a>
                                    </li>
                                }
                                @if (Model.Products.PageCount > Model.Products.EndPage)
                                {
                                    <li class="paginate_button next" id="DataTables_Table_0_next">
                                        <a aria-controls="DataTables_Table_0" data-dt-idx="1" tabindex="0">...</a>
                                    </li>
                                    <li class="paginate_button next" id="DataTables_Table_0_next">
                                        <a href="/Admin/Products/Index?pageId=@(Model.Products.PageCount)&take=@Model.Products.Take&filter=@Model.Products.Filter&CategoryId=@(Model.Products.CategoryId)"
                                           aria-controls="DataTables_Table_0" data-dt-idx="1" tabindex="0">@Model.Products.PageCount</a>
                                    </li>
                                }
                                @if (Model.Products.PageId < Model.Products.PageCount)
                                {
                                    <li class="paginate_button ">
                                        <a href="/Admin/Products/Index?pageId=@(Model.Products.PageId + 1)&take=@Model.Products.Take&filter=@Model.Products.Filter&CategoryId=@(Model.Products.CategoryId)"
                                           aria-controls="DataTables_Table_0" data-dt-idx="1" tabindex="0">»</a>
                                    </li>
                                }


                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>



