@using Shared.Domain.Enums
<div id="chargeModal" class="modal-overlay" style="display: none;">
    <div class="modal-container">
        <div class="modal-header">
            <h3>شارژ کیف پول</h3>
            <button class="WalletModal-closeBtn">&times;</button>
        </div>
        <div class="WalletModalBody">
            <div class="Wallet-input-group">
                <label>مبلغ (ریال):</label>
                <input type="number" id="rialAmount" placeholder="مبلغ را به ریال وارد کنید" class="Wallet-modal-input">
                <small id="tomanHint" class="toman-hint"></small>
            </div>
            <div class="Wallet-input-group">
                <label>توضیحات:</label>
                <input type="text" id="chargeWalletDescription" value="شارژ کیف پول" class="Wallet-modal-input">
            </div>

            <!-- سه گزینه درگاه پرداخت -->
            <div class="payment-gateways">
                <label class="gateway-label">انتخاب درگاه پرداخت:</label>
                <div class="gateway-options">
                    @foreach (var item in Enum.GetValues(typeof(TransactionPortal)).Cast<TransactionPortal>())
                    {
                        if (item != TransactionPortal.دستی_ادمین)
                        {
                            <label class="gateway-option">
                                <input type="radio" name="paymentGateway" id="Portal" value="@item">
                                <span>‌@item.ToString().Replace("_", " ")</span>
                            </label>
                        }

                    }
                </div>
            </div>

            <div class="WalleterrorMsg" id="WalleterrorMsg"></div>
            <button id="chargeBtn" class="Wallet-charge-button">شارژ کیف پول</button>
        </div>
    </div>
</div>