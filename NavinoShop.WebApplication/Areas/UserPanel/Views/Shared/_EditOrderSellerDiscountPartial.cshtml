@using Discount.Application.Contract.OrderDiscounts.Command
@model UpsertOrderDiscountCommandModel

<div class="modal-body">
    <form id="addDiscountForm">
        <input type="hidden" id="DiscountId" value="@Model.Id" asp-for="Id" />
        <h4>ویرایش تخفیف</h4>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group mb-3">
            <label asp-for="Title" class="control-label">عنوان تخفیف</label>
            <input asp-for="Title" id="DiscountTitle" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Percent" class="control-label">درصد تخفیف</label>
            <input asp-for="Percent" id="DiscountPercent" class="form-control" />
            <span asp-validation-for="Percent" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Code" class="control-label">کد تخفیف</label>
            <input asp-for="Code" id="DiscountCode" class="form-control" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Count" class="control-label">تعداد</label>
            <input asp-for="Count" id="DiscountCount" class="form-control" />
            <span asp-validation-for="Count" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label class="control-label">تاریخ شروع</label>
            <input asp-for="StartDate" type="text" id="StartDate" name="StartDate" class="form-control" autocomplete="off" />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label class="control-label">تاریخ پایان</label>
            <input asp-for="EndDate" type="text" id="EndDate" name="EndDate" class="form-control" autocomplete="off" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>

        <div class="modal-footer p-4">
            <button type="button" class="btn btn-default pull-left" onclick="close_Modal_Ajax()">خروج</button>
            <button type="button" onclick="EditOrderSellerDiscount(this)" class="btn btn-primary">ثبت تخفیف</button>
        </div>
    </form>
</div>
<script>

    $("#StartDate").persianDatepicker({
        formatDate: "YYYY/MM/DD",
        persianNumbers: false
    });

    $("#EndDate").persianDatepicker({
        formatDate: "YYYY/MM/DD",
        persianNumbers: false
    });


</script>