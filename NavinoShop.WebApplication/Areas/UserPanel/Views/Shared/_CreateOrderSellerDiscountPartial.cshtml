@using Discount.Application.Contract.OrderDiscounts.Command
@model int //ShopId

<div class="modal-body">
    <form id="addDiscountForm" asp-action="AddDiscount" asp-controller="Discount" method="post">
        <h4>افزودن تخفیف</h4>
        <input type="hidden" id="ShopId" value="@Model" />
        <div class="form-group mb-3">
            <label for="DiscountTitle" class="control-label">عنوان تخفیف</label>
            <input id="DiscountTitle" class="form-control" />
            <span class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label for="DiscountPercent" class="control-label">درصد تخفیف</label>
            <input id="DiscountPercent" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label for="DiscountCode" class="control-label">کد تخفیف</label>
            <input id="DiscountCode" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label for="DiscountCount" class="control-label">تعداد</label>
            <input id="DiscountCount" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label for="StartDate" class="control-label">تاریخ شروع</label>
            <input type="text" id="StartDate" name="StartDate" class="form-control" autocomplete="off" />
        </div>

        <div class="form-group mb-3">
            <label for="EndDate" class="control-label">تاریخ پایان</label>
            <input type="text" id="EndDate" name="EndDate" class="form-control" autocomplete="off" />
        </div>

        <div class="modal-footer p-4">
            <button type="button" class="btn btn-default pull-left" onclick="close_Modal_Ajax()">خروج</button>
            <button type="button" onclick="CreateOrderSellerDiscount(this)" class="btn btn-primary">ثبت تخفیف</button>
        </div>
    </form>
</div>
<script>

    $("#StartDate").persianDatepicker({
        formatDate: "YYYY/MM/DD",
        persianNumbers: false
    });

    $("#EndDate").persianDatepicker({
        formatDate: "YYYY/MM/DD",
        persianNumbers: false
    });


</script>