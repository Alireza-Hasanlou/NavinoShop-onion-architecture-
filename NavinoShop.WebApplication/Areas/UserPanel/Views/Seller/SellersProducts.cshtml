@using Query.Contract.UI.UserPanel.Seller
@using Shared.Application
@using Shared.Domain.Enums
@model ProductsForSellerPaging
@{
    Layout = "_PanelLayout";
    ViewData["title"] = "محصولات فروشگاه ";
}

<div class="box">
    <div class="box-body">
        <div id="customTableWrapper" class="custom-table-wrapper">
            <div class="box-header">
                <h3 class="box-title">@Model.Title</h3>
            </div>

            <div class="row col-12">
                <form id="filterForm">
                    <input type="hidden" asp-for="SellerId" />
                    <input type="hidden" asp-for="PageId" />

                    <div class="row col col-lg-12">
                        <div class="col col-lg-2 col-sm-12">
                            <label>
                                جستجو:
                                <input asp-for="Filter" name="filter" type="search" class="form-control input-sm" placeholder="" aria-controls="customDataTable">
                            </label>
                        </div>
                        <div class="col col-lg-2 col-sm-12">
                            <label>
                                نمایش
                                <select asp-for="Take" name="take" aria-controls="customDataTable" class="form-control input-sm">
                                    <option value="5">5</option>
                                    <option value="10">10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                    <option value="100">100</option>
                                </select>
                            </label>
                        </div>
                        <div class="col col-lg-2 col-sm-12">
                            <button class="btn btn-info" title="جست و جو"><i class="fa fa-search"></i></button>
                        </div>
                        <div class="col col-lg-2 col-sm-12">
                            <a onclick="open_Modal_Ajax('/Profile/Seller/AddProductToShop?Id=@Model.SellerId','product-modal')" class="btn btn-success">افزودن محصول جدید</a>
                            <a href="/Profile/OrderDiscounts/Index/@Model.SellerId" class="btn custom-btn-discount">مدیریت تخفیفات</a>
                        </div>
                   
                    </div>
                    <br />
                </form>
            </div>

            <div class="row">
                <div class="col-sm-12">
                    @if (Model.products.Any())
                    {
                        <div class="custom-responsive-table">
                            <table class="custom-data-table" id="globalCustomTable" role="grid">
                                <thead>
                                    <tr role="row">
                                        <th>تصویر</th>
                                        <th>عنوان</th>
                                        <th>موجودی</th>
                                        <th>قیمت</th>
                                        <th>توضیح کوتاه</th>
                                        <th>وزن</th>
                                        <th>وضعیت</th>
                                        <th>تخفیف ادمین</th>
                                        <th>تخفیف فروشگاه</th>
                                        <th>تاریخ ایجاد</th>
                                        <th>تاریخ ویرایش</th>
                                        <th>تعداد فروش</th>
                                        <th>عملیات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.products)
                                    {
                                        <tr id="row_@item.ProductSellId" class="custom-table-row">
                                            <td data-label="تصویر">
                                                <img class="custom-table-image" style="width:100px" src="@FileDirectories.ProductImageDirectory100@item.ImageName" />
                                            </td>
                                            <td data-label="عنوان">@item.Title</td>
                                            <td data-label="موجودی">@item.Count</td>
                                            <td data-label="قیمت">@item.Price</td>
                                            <td data-label="توضیح کوتاه">@item.ShortDescription</td>
                                            <td data-label="وزن">@item.Weight</td>
                                            <td data-label="وضعیت">
                                                @{
                                                    string title = item.Active ? "غیر فعال شود ؟؟؟" : "فعال شود ؟؟؟";
                                                    string text = item.Active ? "بعد از غیر فعال شدن این محصول نمایش داده نمیشود ." : "بعد از فعال شدن این محصول نمایش داده میشود";
                                                    string cancel = item.Active ? "فعال بماند" : "غیر فعال بماند";
                                                    string confirm = item.Active ? "غیر فعال شود" : "فعال شود";
                                                }
                                                <div onclick="AjaxSweetNotDelete('@title', '@text', 'question', '@confirm', '@cancel', '/Profile/Seller/ChangeProductActivation', '@item.ProductSellId')" class="custom-switch">
                                                    <input id="switch_@item.ProductSellId" @(item.Active ? "checked" : "") type="checkbox">
                                                    <div class="custom-slider">
                                                       
                                                    </div>
                                                </div>
                                            </td>
                                            <td>@item.AdminDiscountPercent %</td>
                                            <td>@item.SellerDiscountPercent %</td>
                                            <td data-label="تاریخ ایجاد">@item.CreateDate.ToPersainDate()</td>
                                            <td data-label="تاریخ ویرایش">@item.UpdateDate.ToPersainDate()</td>
                                            <td data-label="تعداد فروش">@item.SoldCount</td>
                                            <td data-label="عملیات">
                                                <div class="custom-btn-group">
                                                    <a onclick="DeleteAjax('آیا از حذف این محصول مطئن هستید؟ ','در صورت نیاز میتوانید محصول را دوباره اضافه کنید', 'warning', 'بله', '/Profile/Seller/DeleteProductSell',@item.ProductSellId)" title="حذف" class="custom-btn custom-btn-danger"><i class="fa fa-trash"></i></a>
                                                    <a onclick="open_Modal_Ajax('/Profile/Seller/EditProduct?Id=@item.ProductSellId','')" title="ویرایش" class="custom-btn custom-btn-warning"><i class="fa fa-edit"></i></a>
                                                    <a onclick="open_Modal_Ajax('/Profile/Discount/AddDiscount/@item.ProductSellId/@item.ProductId','')" title="تخفیف" class="custom-btn custom-btn-discount"><i class="fa fa-tag"></i></a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="custom-empty-message">موردی برای نمایش موجود نیست</p>
                    }
                </div>
            </div>
            @if (Model.PageCount > 1)
            {
                <div class="custom-pagination-container">
                    <div class="row">
                        <div class="col-12">
                            <div id="custom-pagination-bg">
                                <ul class="custom-pagination">
                                    @if (Model.PageId > 1)
                                    {
                                        <li class="custom-page-item">
                                            <a href="/Profile/Seller/SellersProducts?sellerId=@Model.SellerId&pageId=@(Model.PageId - 1)&take=@Model.Take&filter=@Model.Filter&CategoryId=@(Model.CategoryId)" class="custom-page-link">
                                                <i class="fas fa-angle-double-right"></i>
                                            </a>
                                        </li>
                                    }

                                    @for (int i = Model.StartPage; i <= Model.EndPage; i++)
                                    {
                                        <li class="custom-page-item @((Model.PageId == i) ? "custom-active" : "")">
                                            <a href="/Profile/Seller/SellersProducts?sellerId=@Model.SellerId&pageId=@(i)&take=@Model.Take&filter=@Model.Filter&CategoryId=@(Model.CategoryId)" class="custom-page-link">@i</a>
                                        </li>
                                    }

                                    @if (Model.PageCount > Model.EndPage)
                                    {
                                        <li class="custom-page-item custom-dots">
                                            <span class="custom-page-link">...</span>
                                        </li>
                                        <li class="custom-page-item">
                                            <a href="/Profile/Seller/SellersProducts?sellerId=@Model.SellerId&pageId=@(Model.EndPage)&take=@Model.Take&filter=@Model.Filter&CategoryId=@(Model.CategoryId)" class="custom-page-link">@Model.EndPage</a>
                                        </li>
                                    }

                                    @if (Model.PageId < Model.PageCount)
                                    {
                                        <li class="custom-page-item">
                                            <a href="/Profile/Seller/SellersProducts?sellerId=@Model.SellerId&pageId=@(Model.PageId + 1)&take=@Model.Take&filter=@Model.Filter&CategoryId=@(Model.CategoryId)" class="custom-page-link">
                                                <i class="fas fa-angle-double-left"></i>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section scripts {
    <script>
        // اسکریپت‌های سفارشی جدول
        $(document).ready(function () {
            // اگر نیاز به سورتینگ دستی دارید
            $('.custom-data-table th').on('click', function() {
                var column = $(this).index();
                var table = $(this).closest('table');
                var rows = table.find('tbody tr').get();

                rows.sort(function(a, b) {
                    var aVal = $(a).find('td').eq(column).text();
                    var bVal = $(b).find('td').eq(column).text();
                    return aVal.localeCompare(bVal);
                });

                $.each(rows, function(index, row) {
                    table.find('tbody').append(row);
                });
            });
        });
    </script>
}