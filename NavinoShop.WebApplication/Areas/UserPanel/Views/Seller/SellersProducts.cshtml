@using Shared.Application
@using Shared.Domain.Enums
@using Shop.Application.Contract.Product.Query
@model ProductsForSellerPaging
@{
    Layout = "_PanelLayout";
    ViewData["title"] = "محصولات فروشگاه ";

}


<div class="box">
    <div class="box-body">
        <div id="example1_wrapper" class="dataTables_wrapper form-inline dt-bootstrap">
            <div class="box-header">
                <h3 class="box-title">@Model.Title</h3>
            </div>

            <div class="row col-12">
                <form>
                    <input type="hidden"  asp-for="SellerId" />
                    <input type="hidden" asp-for="PageId" />

                    <div class="row col col-lg-12">
                        <div class="col col-lg-2 col-sm-12">
                            <label>
                                جستجو:
                                <input asp-for="Filter" name="filter" type="search" class="form-control input-sm" placeholder="" aria-controls="DataTables_Table_0">
                            </label>
                        </div>
                        <div class="col col-lg-2 col-sm-12">
                            <label>
                                نمایش
                                <select asp-for="Take" name="take" aria-controls="DataTables_Table_0" class="form-control input-sm">
                                    <option value="5">5</option>
                                    <option value="10">10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                    <option value="100">100</option>
                                </select>

                            </label>
                        </div>
                        <div class="col col-lg-2 col-sm-12">
                            <button class="btn btn-info" title="جست و جو"><i class="fa fa-search"></i></button>
                        </div>
                        <div class="col col-lg-2 col-sm-12">
                            <a onclick="open_Modal_Ajax('/Seller/AddProductToShop?Id=@Model.SellerId','product-modal')" class="btn btn-success">افزودن محصول جدید</a>
                        </div>
                    </div>
                    <br />
                </form>
            </div>
            <div class="row">
                <div class="col-sm-12">
                            @if(Model.products.Any())
                            {
                    <table class="DataTable table table-bordered table-striped dataTable" role="grid">
                        <thead>
                            <tr role="row">
                                <th>تصویر</th>
                                <th>عنوان</th>
                                <th>موجودی</th>
                                <th>قیمت</th>
                                <th>توضیح کوتاه</th>
                                <th> وزن</th>
                                <th>وضعیت</th>
                                <th>تاریخ ایجاد</th>
                                <th>تاریخ ویرایش</th>
                                <th>تعداد فروش</th>
                                <th>عملیات</th>

                            </tr>
                        </thead>

                        <tbody>
                           
                            @foreach (var item in Model.products)
                            {
                                <tr id="@item.Id">
                                    <td>
                                        <img style="width:100px" src="@FileDirectories.ProductImageDirectory100@item.ImageName" />
                                    </td>
                                    <td>@item.Title</td>
                                    <td>@item.Count</td>
                                    <td>@item.Price</td>
                                    <td>@item.ShortDescription</td>
                                    <td>@item.Weight</td>
                                    <td>
                                        @{
                                            string title = item.Active ? "غیر فعال شود ؟؟؟" : "فعال شود ؟؟؟";
                                            string text = item.Active ? "بعد از غیر فعال شدن این  محصول  نمایش داده نمیشود ." : "بعد از فعال شدن این محصول نمایش داده میشود";
                                            string cancel = item.Active ? "فعال بماند" : "غیر فعال بماند";
                                            string confirm = item.Active ? "غیر فعال شود" : "فعال شود";
                                        }
                                        <!-- From Uiverse.io by Galahhad -->
                                        <div onclick="AjaxSweetNotDelete(
                                                                                                                                             '@title',
                                                                                                                                             '@text',
                                                                                                                                             'question',
                                                                                                                                             '@confirm',
                                                                                                                                              '@cancel',
                                                                                                                                              '/Profile/Seller/ChangeProductActivation',
                                                                                                                                              '@item.Id' )" class="switch">
                                            <input id="@item.Id" @(item.Active ? "checked" : "") type="checkbox">
                                            <div class="slider">
                                                <div class="circle">
                                                    <svg class="cross" xml:space="preserve" style="enable-background:new 0 0 512 512" viewBox="0 0 365.696 365.696" y="0" x="0" height="6" width="6" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" xmlns="http://www.w3.org/2000/svg">
                                                    <g>
                                                    <path data-original="#000000" fill="currentColor" d="M243.188 182.86 356.32 69.726c12.5-12.5 12.5-32.766 0-45.247L341.238 9.398c-12.504-12.503-32.77-12.503-45.25 0L182.86 122.528 69.727 9.374c-12.5-12.5-32.766-12.5-45.247 0L9.375 24.457c-12.5 12.504-12.5 32.77 0 45.25l113.152 113.152L9.398 295.99c-12.503 12.503-12.503 32.769 0 45.25L24.48 356.32c12.5 12.5 32.766 12.5 45.247 0l113.132-113.132L295.99 356.32c12.503 12.5 32.769 12.5 45.25 0l15.081-15.082c12.5-12.504 12.5-32.77 0-45.25zm0 0"></path>
                                                                                            </g>
                                                                                        </svg>
                                                    <svg class="checkmark" xml:space="preserve" style="enable-background:new 0 0 512 512" viewBox="0 0 24 24" y="0" x="0" height="10" width="10" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" xmlns="http://www.w3.org/2000/svg">
                                                    <g>
                                                    <path class="" data-original="#000000" fill="currentColor" d="M9.707 19.121a.997.997 0 0 1-1.414 0l-5.646-5.647a1.5 1.5 0 0 1 0-2.121l.707-.707a1.5 1.5 0 0 1 2.121 0L9 14.171l9.525-9.525a1.5 1.5 0 0 1 2.121 0l.707.707a1.5 1.5 0 0 1 0 2.121z"></path>
                                                                                            </g>
                                                                                        </svg>
                                                </div>
                                            </div>
                                        </div>

                                    </td>
                                    <td>@item.CreateDate.ToPersainDate()</td>
                                    <td>@item.UpdateDate.ToPersainDate()</td>
                                    
                                        <td>@item.SoldCount</td>
                                        <td>
                                        <div class="btn-group">
                                            <a onclick="DeleteAjax('آیا از حذف این محصول مطئن هستید؟ ','در صورت نیاز میتوانید محصول را دوباره اضافه کنید', 'warning', 'بله', '/Profile/Seller/DeleteProductSell',@item.Id)" class="btn btn-danger"><i class="fa fa-trash"></i></a>
                                              <a onclick="open_Modal_Ajax('/Profile/Seller/EditProduct?Id=@item.Id','')" class="btn btn-warning"><i class="fa fa-edit"></i></a>
                                        </div>
                                    </td>

                                </tr>
                                }
                            </tbody>
                      
                    </table>
                        }
                        else
                        {
                            <p>موردی برای نمایش موجود نیست</p>
                        }
                </div>
            </div>

            @if (Model.PageCount > 1)
            {
           
                <div class="container">
                    <div class="row">
                        <div class="col-12">
                            <div id="pagination-bg">
                                <ul class="pagination justify-content-center pagination-sm">
                                    @if (Model.PageId > 1)
                                    {
                                        <li class="page-item" id="previous-page">
                                            <a href="/Seller/SellersProducts?sellerId=@Model.SellerId&pageId=@(Model.PageId - 1)&take=@Model.Take&filter=@Model.Filter&CategoryId=@(Model.CategoryId)" class="page-link">
                                               <i class="fas fa-angle-double-right"></i> 
                                            </a>
                                        </li>
                                    }
                                    @for (int i = Model.StartPage; i <= Model.EndPage; i++)
                                    {
                                        <li  class="page-item current-page @((Model.PageId == i) ? "active" : "") ">
                                            <a href="/Seller/SellersProducts?sellerId=@Model.SellerId&pageId=@(i)&take=@Model.Take&filter=@Model.Filter&CategoryId=@(Model.CategoryId)" class="page-link">@i</a>
                                            </li>
                                    }
                                    @if (Model.PageCount > Model.EndPage)
                                    {
                                        <li class="paginate_button next" id="DataTables_Table_0_next">
                                            <a   aria-controls="DataTables_Table_0" data-dt-idx="1" tabindex="0">...</a>
                                        </li>
                                 
                                          <li class="page-item current-page ">
                                              <a href="/Seller/SellersProducts?sellerId=@Model.SellerId&pageId=@(Model.EndPage)&take=@Model.Take&filter=@Model.Filter&CategoryId=@(Model.CategoryId)" class="page-link @((Model.PageId == Model.EndPage) ? "active" : "") ">@Model.EndPage</a>
                                          </li>
                                    }

                                    @if (Model.PageId < Model.PageCount)
                                    {
                                        <li class="page-item" id="previous-page">
                                            <a href="/Seller/SellersProducts?sellerId=@Model.SellerId&pageId=@(Model.PageId + 1)&take=@Model.Take&filter=@Model.Filter&CategoryId=@(Model.CategoryId)" class="page-link">
                                                <i class="fas fa-angle-double-left"></i>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            }
     
        </div>
    </div>
</div>
<script>

       $('.DataTable').DataTable({
        paging:false,
        autoWidth: true,
        lengthChange: false,
        searching: false,
        ordering: true,
        scroll: true,
        info: false,

    });

</script>
