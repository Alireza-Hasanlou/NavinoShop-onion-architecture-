@using Shared.Domain.Enums
@model Query.Contract.UI.UserPanel.Wallet.WalletDetailQueryModel
@{
    Layout = "_PanelLayout";
    var errorMessage = TempData["error"] as string;
}



<div class="wallet-card">
    <div class="wallet-header">
        <div class="wallet-label">
            <span class="icon-placeholder">💰</span> کیف پول من
        </div>
        <div class="balance-box">
            <div class="balance-title">
                <span>موجودی قابل برداشت</span>
                <span>تومان</span>
            </div>
            <div class="balance-amount">
                <span data-format="money" class="amount-number">@Model.Balance</span>
                <span class="amount-currency">تومان</span>
            </div>
        </div>
    </div>
    <div class="charge-btn-wrapper">
        <button id="showChargeModalBtn" class="charge-btn">
            <span class="icon-placeholder">➕</span>
            افزایش موجودی
        </button>
    </div>

    <!-- دوتا المنت مربعی: کال واریزی‌ها و کل مبالغ خرج شده -->
    <div class="stats-grid">
        <div class="stat-square">
            <div class="stat-icon">⬇️</div>
            <div class="stat-label">کل واریزی‌ها</div>
            <div data-format="money" style="font-size:0.8rem; color:#fcb941; margin-top: 8px; font-weight:600;">+@Model.TotalDeposits</div>
        </div>
        <div class="stat-square">
            <div class="stat-icon">⬆️</div>
            <div class="stat-label">کل خرج کرده</div>
            <div data-format="money" style="font-size:0.8rem; color:#c17a2b; margin-top: 8px; font-weight:600;">-@Model.TotalWithdrawals</div>
        </div>
    </div>

    <!-- پنج تراکنش آخر -->
    <div class="transactions-header">
        <div class="transactions-title">
            <span class="icon-placeholder">🕒</span> آخرین تراکنش‌ها
        </div>

    </div>
    <div class="transactions-list">
    </div>

    <div id="LoadMore">
    </div>

</div>
<!-- فایل: modal-charge.html (محتوای پارشیال) -->


<div id="chargeModal" class="modal-overlay" style="display: none;">
    <div class="modal-container">
        <div class="modal-header">
            <h3>شارژ کیف پول</h3>
            <button class="WalletModal-closeBtn">&times;</button>
        </div>
        <div class="WalletModalBody">
            <div class="Wallet-input-group">
                <label>مبلغ (ریال):</label>
                <input type="number" id="rialAmount" placeholder="مبلغ را به ریال وارد کنید" class="Wallet-modal-input">
                <small id="tomanHint" class="toman-hint"></small>
            </div>
            <div class="Wallet-input-group">
                <label>توضیحات:</label>
                <input type="text" id="chargeWalletDescription" value="شارژ کیف پول" class="Wallet-modal-input">
            </div>

            <!-- سه گزینه درگاه پرداخت -->
            <div class="payment-gateways">
                <label class="gateway-label">انتخاب درگاه پرداخت:</label>
                <div class="gateway-options">
                    @foreach (var item in Enum.GetValues(typeof(TransactionPortal)).Cast<TransactionPortal>())
                    {
                        if (item != TransactionPortal.دستی_ادمین)
                        {
                            <label class="gateway-option">
                                <input type="radio" name="paymentGateway" id="Portal" value="@item">
                                <span>‌@item.ToString().Replace("_", " ")</span>
                            </label>
                        }

                    }
                </div>
            </div>

            <div class="WalleterrorMsg" id="WalleterrorMsg"></div>
            <button id="chargeBtn" class="Wallet-charge-button">شارژ کیف پول</button>
        </div>
    </div>
</div>


@section scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            LoadWalletTransactions(0);
        });

        $('#showChargeModalBtn').click(function() {
            $('#chargeModal').fadeIn();
        });
    </script>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        TempData["error"] = "";
        <script>
                  closeModal();
            AlerSweetWithTimer("@errorMessage","error", "center");
        </script>

    }
}

