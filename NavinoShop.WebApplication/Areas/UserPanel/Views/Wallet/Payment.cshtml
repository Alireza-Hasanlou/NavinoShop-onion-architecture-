
@using NavinoShop.WebApplication.Utility.ViewModels
@model PaymentStatusViewModel

@{
    Layout = "_Layout";
}
<section class="inner-page" id="contact-page">


    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="content">
                    <div class="row">
                        <div class="col-12">
                            <div id="notfound">
                                <div class="notfound-bg">
                                    <div></div>
                                    <div></div>
                                    <div></div>
                                    <div></div>
                                </div>
                                <div class="notfound">
                                  
                                    @if (Model.Status==100)
                                    {
                                        <h4 class="text-success">@Model.Message</h4>
                                    }
                                    else
                                    {
                                        <p class="text-success">عملیات ناموفق!.</p>
                                    }
                                    <p>کد پیگیری:@Model.RefId</p>
                                    <br />
                                    <a href="/Profile/Wallet">بازگشت به کیف پول</a>
                                    <div class="notfound-social">
                                        <a href="#"><img src="/images/social/twitter.png" alt="توئیتر" width="18px"></a>
                                        <a href="#"><img src="/images/social/insta.png" alt="اینستاگرام" width="18px"></a>
                                        <a href="#"><img src="/images/social/linkedin.png" alt="لینکدین" width="18px"></a>
                                        <a href="#"><img src="/images/social/facebook.png" alt="فیس بوک" width="18px"></a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
